# Aito predictive database connection.
# Local dev: copy this to .env, fill in values, then `./do dev`.
# Production: aito-demo-server/.env.local supplies AITO_<DEMO_NAME>_* and the
# yaml's `env:` block remaps to AITO_API_URL / AITO_API_KEY.
# This is a READ-ONLY key (verified: reads ok, schema/data writes 401) — safe to
# commit. Copy this file to .env and it works as-is for local dev.
AITO_API_URL=https://shared.aito.ai/db/aito-agent-demo
# read only key, safe to commit. If you want to write to the db, create a personal key in the Aito console and put it here (or in .env.local which overrides .env).
AITO_API_KEY=08b98adef5a80260a41273d5efb9e050fc24cef3dece1eb725c675b4bb1dd5a8

OPENAI_MODEL_URL="TODO"
OPENAI_RESOURCE_NAME="TODO"
OPENAI_MODEL_NAME="TODO"
OPENAI_MODEL_DEPLOYMENT="TODO"
OPENAI_MODEL_API_VERSION="TODO"
OPENAI_MODEL_API_KEY="TODO"
