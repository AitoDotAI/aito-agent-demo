# Copy to ../.env (the benchmark reads the parent demo's .env) and fill in.
# The bench loads env from the repo-root .env so it shares Aito creds with the demo.

# --- Aito ---
AITO_API_URL=https://shared.aito.ai/db/your-db-here
AITO_API_KEY=your-read-key-here        # used for _predict
AITO_RW_KEY=your-write-key-here        # used by aito/upload.py; falls back to AITO_API_KEY if blank

# --- Azure OpenAI (LLM baselines + Aito assist path) ---
OPENAI_MODEL_URL=https://<region>.api.cognitive.microsoft.com
OPENAI_RESOURCE_NAME=aito-demo-openai
OPENAI_MODEL_NAME=gpt-5-mini
OPENAI_MODEL_DEPLOYMENT=gpt-5-mini
OPENAI_MODEL_API_VERSION=2024-08-01-preview
OPENAI_MODEL_API_KEY=your-azure-openai-key-here
